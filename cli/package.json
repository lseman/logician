{
  "name": "logician-ink-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript + React + Ink CLI inspired by Claude Code",
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "binary": "bun build src/index.tsx --compile --outfile ../logician"
  },
  "dependencies": {
    "cli-highlight": "^2.1.11",
    "clipboardy": "^5.3.1",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "markdown-it": "^14.1.1",
    "markdown-toc": "^1.2.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.20",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
