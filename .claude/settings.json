{
  "permissions": {
    "allow": [
      "Bash(python -c \"from src.tools.core import read_file, write_file, edit_file, apply_edit_block, bash, glob_files, grep_files, think, todo; print\\(''All imports successful''\\)\")",
      "Bash(python -m pytest test/test_core_tools.py -v --tb=short)",
      "Bash(/tmp/core_tools_summary.txt:*)",
      "Read(//tmp/**)",
      "Bash(pytest test/test_tool_registry_enhancements.py -q --tb=no)",
      "Bash(pytest test/test_agent_loop.py test/test_core_tools.py test/test_classify.py test/test_turn_state.py test/test_guardrails.py test/test_prompt_builder.py test/test_dispatcher.py test/test_agent_types.py -v --tb=short)",
      "Bash(python -m pytest test/test_agent_loop.py -v)",
      "Bash(pytest test/test_agent_loop.py -q --tb=long)",
      "Bash(python -c \":*)",
      "Bash(python -c \"from src.config import Config; c = Config\\(pre_turn_thinking=False\\); print\\(c.pre_turn_thinking\\)\")",
      "Bash(python -m pytest test/test_agent_loop.py -v --no-header)",
      "Bash(python -m pytest test/ --no-header -q)",
      "Bash(python -m pytest test/test_agent_runtime_public.py::AgentRuntimePublicTests::test_thinking_callback_streams_before_fast_path_response test/test_tool_registry_enhancements.py::ToolRegistryEnhancementsTests::test_python_skill_module_can_register_tools_via_tool_decorator -v --no-header --no-cov)"
    ]
  },
    "hooks": {
      "PostToolUse": [
        {
          "matcher": "Edit|Write|Bash",
          "hooks": [
            {
              "type": "command",
              "command": "code-review-graph update",
              "timeout": 5000
            }
          ]
        }
      ],
      "SessionStart": [
        {
          "matcher": "",
          "hooks": [
            {
